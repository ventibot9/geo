# 数据库配置
DATABASE_URL=postgresql://geo_user:geo_password@localhost:5432/geo_platform
DATABASE_USER=geo_user
DATABASE_PASSWORD=geo_password
DATABASE_NAME=geo_platform

# Redis配置
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT配置
JWT_SECRET=your-secret-key-change-in-production-use-strong-random-string
JWT_EXPIRES_IN=7d

# API端口
BACKEND_PORT=3001
FRONTEND_PORT=3000
AI_SERVICE_PORT=8000

# OpenAI配置
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic配置
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# 本地模型配置（可选）
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama2:7b

# 爬虫配置
SCANNER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
SCANNER_TIMEOUT=30
SCANNER_MAX_PAGES=1000

# 监控配置
MONITOR_INTERVAL=3600  # 每小时监控一次
MONITOR_ENGINES=chatgpt,claude,wenxin,perplexity

# 环境变量
NODE_ENV=development

# 日志级别
LOG_LEVEL=info
