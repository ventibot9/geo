# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/geo_platform?schema=public"

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT密钥
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# 加密密钥
BCRYPT_ROUNDS=10

# CORS配置
CORS_ORIGIN=http://localhost:3000

# AI服务配置
AI_SERVICE_URL=http://localhost:8000
AI_API_KEY=your-ai-api-key

# 日志配置
LOG_LEVEL=info
